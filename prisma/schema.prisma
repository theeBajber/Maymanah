generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Required Models ───
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Core User ───
model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String?   @unique
  emailVerified         DateTime?
  image                 String?
  password              String?   // Only for credentials login; null for OAuth users
  gender                String?
  role                  UserRole  @default(STUDENT)
  twoFactorEnabled      Boolean   @default(false)
  xp                    Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  loginSessions         LoginSession[]

  profile               Profile?
  enrollments           Enrollment[]
  teachings             Mentorship[]     @relation("TeacherMentorships")
  learnings             Mentorship[]     @relation("StudentMentorships")
  sentMessages          Message[]        @relation("SentMessages")
  receivedMessages      Message[]        @relation("ReceivedMessages")
  donations             Donation[]
  appointments          Appointment[]    @relation("TeacherAppointments")
  availabilities        Availability[]
  assessments           Assessment[]
  ijazahs               Ijazah[]
  bookmarks             Bookmark[]
  recitationJournals    RecitationJournal[]
  quranProgress         QuranProgress[]
  ustadhProfile         UstadhProfile?
  studentNotes          StudentNote[]     @relation("UstadhNotes")
  studentNoteSubjects   StudentNote[]     @relation("StudentNotes")
  lessonProgress        LessonProgress[]
  submissions           Submission[]
  userAnalytics         UserAnalytics[]
  twoFactorOTPs         TwoFactorOTP[]
  notifications         Notification[]
  courseReviews         CourseReview[]

  @@index([role])
}

model Profile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                  String?
  timezone             String   @default("Africa/Nairobi")
  phone                String?
  country              String?
  quranLevel           String?  // beginner, intermediate, advanced
  theme                String   @default("system") // light, dark, system
  language             String   @default("en") // en, ar, etc.
  quranFont            String   @default("default") // default, uthmani, etc.
  emailNotifications   Boolean  @default(true)
  studyReminders       Boolean  @default(true)
  reminderTime         String   @default("09:00") // HH:MM format
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── Ustadh Profile ───
model UstadhProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isApproved        Boolean  @default(false)
  reliabilityScore  Float?   // computed from session join rate
  bio               String?
  qualifications    String?
  ijazah            String?   // Ijazah certification details
  qiraah            String?   // Qiraah specialization (Hafs, Warsh, etc.)
  availableForTeaching Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([isApproved])
}

// ─── Login Sessions ───
model LoginSession {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName      String   // e.g., "Chrome on Windows"
  ipAddress       String
  lastActivity    DateTime @default(now()) @updatedAt
  createdAt       DateTime @default(now())
  isActive        Boolean  @default(true)

  @@index([userId])
  @@index([isActive])
}

// ─── Two-Factor Authentication ───
model TwoFactorOTP {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([userId])
}

// ─── Curriculum ───
model Course {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  description   String?
  category      CourseCategory
  image         String?
  enrollmentKey String?        @unique
  isPublished   Boolean        @default(true)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  enrollments    Enrollment[]
  lessons        Lesson[]
  exams          Exam[]
  ijazahs        Ijazah[]
  userAnalytics  UserAnalytics[]
  reviews        CourseReview[]
}

model Lesson {
  id          String  @id @default(cuid())
  courseId    String
  course      Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  content     String? // Rich text / video embed / interactive content
  videoUrl    String?
  audioUrl    String?
  order       Int
  duration    Int?    // minutes
  isPublished Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  exam            Exam?
  lessonProgress  LessonProgress[]

  @@index([courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean  @default(false)
  score       Float?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@index([lessonId])
}

model Enrollment {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus  @default(ACTIVE)
  progress    Int               @default(0) // 0-100
  enrolledAt  DateTime          @default(now())
  passedAt    DateTime?
  completedAt DateTime?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

// ─── Mentorship (Teacher → Student) ───
model Mentorship {
  id        String            @id @default(cuid())
  teacherId String
  teacher   User              @relation("TeacherMentorships", fields: [teacherId], references: [id], onDelete: Cascade)
  studentId String
  student   User              @relation("StudentMentorships", fields: [studentId], references: [id], onDelete: Cascade)
  status    MentorshipStatus  @default(ACTIVE)
  startedAt DateTime          @default(now())
  endedAt   DateTime?

  appointments   Appointment[]
  recurringSlots RecurringSlot[]

  @@unique([teacherId, studentId])
  @@index([teacherId])
  @@index([studentId])
}

// ─── Calendar / Appointments ───
model Appointment {
  id           String                 @id @default(cuid())
  mentorshipId String
  mentorship   Mentorship             @relation(fields: [mentorshipId], references: [id], onDelete: Cascade)
  teacherId    String
  teacher      User                   @relation("TeacherAppointments", fields: [teacherId], references: [id])
  title        String?
  description  String?
  startTime    DateTime
  endTime      DateTime?
  meetingUrl   String?                // Jitsi / Daily room link
  status       AppointmentStatus      @default(SCHEDULED)
  sessionType  AppointmentSessionType @default(DAILY_HIFDH)
  startedAt    DateTime?
  endedAt      DateTime?
  surahNumber  Int?
  verseNumber  Int?
  notes        StudentNote[]
  sessionPlan  SessionPlan?
  joinedAt     DateTime?
  missed       Boolean                @default(false)
  createdAt    DateTime               @default(now())

  @@index([mentorshipId])
  @@index([teacherId])
  @@index([startTime])
}

model RecurringSlot {
  id           String             @id @default(cuid())
  mentorshipId String
  mentorship   Mentorship         @relation(fields: [mentorshipId], references: [id], onDelete: Cascade)
  type         AppointmentSessionType
  dayOfWeek    Int                // 0 = Sunday, 6 = Saturday
  startTime    String             // "09:00"
  duration     Int                // minutes (15 for DAILY_HIFDH, 60 for MURAJA)
  createdAt    DateTime           @default(now())

  @@unique([mentorshipId, type, dayOfWeek])
  @@index([mentorshipId])
}

model Availability {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek    Int       // 0 = Sunday, 6 = Saturday
  startTime    String    // "09:00"
  endTime      String    // "17:00"
  isRecurring  Boolean   @default(true)
  specificDate DateTime?

  @@index([userId])
}

// ─── Chat ───
model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// ─── Exams & Assessments ───
enum ExamType {
  QUIZ
  MIDTERM
  FINAL
  ASSIGNMENT
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
  ESSAY
}

enum Difficulty {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYZE
  EVALUATE
  CREATE
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

model Exam {
  id              String      @id @default(cuid())
  courseId        String
  course          Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId        String?     @unique
  lesson          Lesson?     @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  examType        ExamType    @default(QUIZ)
  durationMinutes Int         @default(60)
  totalMarks      Float       @default(100)
  passMark        Float       @default(50)
  startTime       DateTime?
  endTime         DateTime?
  isPublished     Boolean     @default(false)
  shuffleQuestions Boolean    @default(true)
  allowReview     Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  questions   Question[]
  submissions Submission[]

  @@index([courseId])
}

model Question {
  id            String       @id @default(cuid())
  examId        String
  exam          Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionText  String
  questionType  QuestionType @default(MCQ)
  options       Json?        // For MCQ: [{text, isCorrect}] or just options
  correctAnswer String?      // For short_answer/essay
  marks         Float        @default(1)
  difficulty    Difficulty   @default(UNDERSTAND)
  orderIndex    Int          @default(0)
  explanation   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  answers Answer[]

  @@index([examId])
}

model Submission {
  id             String           @id @default(cuid())
  examId         String
  exam           Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId      String
  student        User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status         SubmissionStatus @default(IN_PROGRESS)
  totalScore     Float?
  attemptNumber  Int              @default(1)
  startedAt      DateTime         @default(now())
  submittedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  answers Answer[]

  @@index([examId, studentId])
  @@index([examId])
  @@index([studentId])
}

model Answer {
  id             String   @id @default(cuid())
  submissionId   String
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerText     String?
  selectedOption Int?     // For MCQ: index of selected option
  isCorrect      Boolean?
  score          Float?
  aiFeedback     String?
  answeredAt     DateTime @default(now())

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@index([questionId])
}

// ─── User Analytics ───
model UserAnalytics {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     String?
  course       Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  metricType   String   // e.g. 'login', 'material_view', 'exam_attempt'
  metricValue  Float?
  metadata     Json?
  recordedAt   DateTime @default(now())

  @@index([userId])
  @@index([metricType])
}

// ─── Ijazah & Progress ───
model Ijazah {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId         String
  course           Course   @relation(fields: [courseId], references: [id])
  issuedAt         DateTime @default(now())
  issuedBy         String?  // Admin name or "SYSTEM"
  certificateUrl   String?
  certificatePdfUrl String?
  verificationCode String? @unique
  expiresAt        DateTime?
  isVerified       Boolean  @default(false)

  @@unique([userId, courseId])
  @@index([userId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surah     Int
  ayah      Int
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, surah, ayah])
  @@index([userId])
}

// ─── AI Assessments ───
model Assessment {
  id         String         @id @default(cuid())
  studentId  String
  student    User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type       AssessmentType
  audioUrl   String?
  transcript String?
  score      Float?         // 0-100
  feedback   String?
  assessedBy String?        // "AI" or teacherId
  createdAt  DateTime       @default(now())

  @@index([studentId])
}

// ─── Session Plan (mentor sets surah/ayah range for a session) ───
model SessionPlan {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  fromSurah     Int
  fromVerse     Int
  toSurah       Int
  toVerse       Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([appointmentId])
}

// ─── Course Reviews (upon completion) ───
model CourseReview {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
}

// ─── Notifications ───
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "session_reminder", "message", "note_added"
  title     String
  body      String?
  metadata  Json?    @default("{}")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

// ─── Donations ───
model Donation {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("USD")
  provider  String   // "stripe" | "mpesa"
  status    String   @default("PENDING") // PENDING, COMPLETED, FAILED
  reference String?  @unique // provider transaction ID or CheckoutRequestID
  anonymous Boolean  @default(false)
  donorId   String?  // null for anonymous
  donor     User?    @relation(fields: [donorId], references: [id])
  createdAt DateTime @default(now())
}

// ─── Student Notes (ustadh-facing) ───
enum NotePriority {
  LOW
  MEDIUM
  HIGH
}

model StudentNote {
  id         String        @id @default(cuid())
  studentId  String
  student    User          @relation("StudentNotes", fields: [studentId], references: [id], onDelete: Cascade)
  ustadhId   String
  ustadh     User          @relation("UstadhNotes", fields: [ustadhId], references: [id], onDelete: Cascade)
  sessionId  String?
  session    Appointment?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  content    String
  priority   NotePriority  @default(MEDIUM)
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([studentId])
  @@index([ustadhId])
  @@index([resolved])
  @@index([sessionId])
}

// ─── Enums ───
enum UserRole {
  STUDENT
  TEACHER
  ADMIN
  SUPERADMIN
}

enum CourseCategory {
  Quran
  Fiqh
  History
  Arabic
  Aqeedah
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum MentorshipStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum AppointmentStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum AppointmentSessionType {
  DAILY_HIFDH
  MURAJA
  EXTRA
}

enum AssessmentType {
  HIFDH_LISTENING
  TAJWEED_EXAM
  VERBAL_TEST
}

// ─── Quran Progress & Recitation ───
model QuranProgress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSurah     Int      @default(1)
  lastVerse     Int      @default(1)
  completedJuz  Int      @default(0) // number of juz fully completed
  lastRecitation DateTime @default(now()) @updatedAt

  @@unique([userId])
  @@index([userId])
}

model RecitationJournal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surahNumber   Int
  fromVerse     Int
  toVerse       Int
  errors        Json?    // Array of error details
  accuracy      Float    @default(0)
  duration      Int      @default(0) // seconds
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Audit Log ───
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  email     String?
  metadata  Json     @default("{}")
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([createdAt])
}
